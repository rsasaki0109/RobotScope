{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://robotscope.dev/schemas/rdm/v0.1/frame.json",
  "title": "RobotScope Frame",
  "type": "object",
  "required": ["frame_id"],
  "properties": {
    "frame_id": { "type": "string" },
    "parent_frame_id": { "type": "string" },
    "transform": {
      "type": "object",
      "properties": {
        "translation": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 3,
          "maxItems": 3
        },
        "rotation": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 4,
          "maxItems": 4,
          "description": "Quaternion xyzw"
        }
      }
    },
    "covariance": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 36,
      "maxItems": 36
    },
    "authority": { "type": "string" },
    "validity": {
      "type": "object",
      "properties": {
        "from_ns": { "type": "integer" },
        "to_ns": { "type": "integer" }
      }
    }
  },
  "additionalProperties": false
}
